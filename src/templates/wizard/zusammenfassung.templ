package wizard

import (
	"steuerpilot-go/internal/models"
	"steuerpilot-go/internal/util"
	"steuerpilot-go/templates/pages"
	"steuerpilot-go/templates/partials"
)

templ Zusammenfassung(sf models.Steuerfall, ergebnis models.Steuerergebnis) {
	@pages.WizardLayout("Zusammenfassung", 4) {
		<div class="space-y-6">
			@partials.TaxResult(ergebnis)
			<div class="grid grid-cols-2 gap-4 text-sm">
				<div class="border rounded-lg p-4">
					<h3 class="font-semibold mb-2 text-gray-700">Personalien</h3>
					<p>{ sf.Personalien.Vorname } { sf.Personalien.Nachname }</p>
					<p class="text-gray-500">{ sf.Personalien.Gemeinde }</p>
				</div>
				<div class="border rounded-lg p-4">
					<h3 class="font-semibold mb-2 text-gray-700">Einkommen</h3>
					<p>{ util.FormatCHF(sf.Einkommen.Haupterwerb.Bruttolohn) }</p>
					<p class="text-gray-500">Bruttolohn</p>
				</div>
			</div>
			<div class="bg-blue-50 border border-blue-200 rounded-lg p-5">
				<h3 class="font-semibold mb-2 text-gray-800">KI-Optimierungsvorschläge</h3>
				<p class="text-sm text-gray-600 mb-3">
					Claude analysiert Ihren Steuerfall und schlägt legale Optimierungsmöglichkeiten vor.
				</p>
				<div id="optimierungen">
					<button
						type="button"
						hx-post="/api/optimize"
						hx-target="#optimierungen"
						hx-swap="innerHTML"
						class="text-sm bg-blue-600 text-white px-4 py-2 rounded font-medium hover:bg-blue-700 transition"
					>
						Optimierungen berechnen (Claude AI)
					</button>
				</div>
			</div>
			<div class="flex justify-between items-center pt-4 border-t">
				<a href="/wizard/vermoegen" class="text-gray-500 hover:underline text-sm">← Zurück</a>
				<div class="flex gap-3">
					<a href="/api/export/pdf" class="text-sm border px-4 py-2 rounded hover:bg-gray-50 transition">
						PDF exportieren
					</a>
					<a href="/ergebnis" class="bg-blue-600 text-white px-6 py-2 rounded font-medium hover:bg-blue-700 transition text-sm">
						Zur Übersicht
					</a>
				</div>
			</div>
		</div>
	}
}
