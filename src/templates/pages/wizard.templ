package pages

import (
	"steuerpilot-go/templates/components"
	"steuerpilot-go/templates/layout"
)

templ WizardLayout(title string, stepIndex int) {
	@layout.Base(title) {
		<main class="max-w-2xl mx-auto px-4 py-8">
			@components.StepIndicator(stepIndex)
			<h2 class="text-xl font-bold mb-6">{ title }</h2>
			{ children... }
		</main>
	}
}
