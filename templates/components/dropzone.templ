package components

// Dropzone renders a file drop zone. Currently unused — a plain input is used in upload.templ.
templ Dropzone(name string) {
	<div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center text-gray-400">
		<input type="file" name={ name } class="sr-only"/>
		<p class="text-sm">Datei hier ablegen oder klicken</p>
	</div>
}
